{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for techx To-Do List Challenge",
  "main": "dist/src/app.js",
  "type": "module",
  "scripts": {
    "dev": "npm run db:deploy && tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/src/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "infra:up": "docker compose up -d db nosql redis",
    "infra:down": "docker compose stop db nosql redis",
    "infra:clean": "docker compose down -v --rmi all",
    "app:up": "docker compose up -d",
    "app:down": "docker compose down",
    "db:deploy": "prisma migrate dev && prisma db seed",
    "seed": "npx prisma db seed",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@sinclair/typebox": "^0.34.49",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/mongodb": "^4.0.6",
    "@types/node": "^22.13.1",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^9.19.0",
    "globals": "^15.14.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}