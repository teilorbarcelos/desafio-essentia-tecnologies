{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for essentia To-Do List Challenge",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "npm run db:deploy && tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "infra:up": "docker compose up -d db nosql redis",
    "infra:down": "docker compose stop db nosql redis",
    "infra:clean": "docker compose down -v --rmi all",
    "app:up": "docker compose up -d",
    "app:down": "docker compose down",
    "db:deploy": "prisma migrate dev && prisma db seed",
    "seed": "npx prisma db seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.13.1",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}